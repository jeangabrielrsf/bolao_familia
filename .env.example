# Banco de dados (PostgreSQL via Supabase ou Docker local)
DATABASE_URL="postgresql://user:pass@host:5432/bolao_copa"

# Supabase (storage para fotos de perfil e arquivos de upload)
SUPABASE_URL="https://xxx.supabase.co"
SUPABASE_SERVICE_KEY="service-role-key"

# Autenticação do painel admin
ADMIN_PASSWORD="your-strong-password"
SESSION_SECRET="random-32-char-string"

# OCR / Visão computacional (extração de palpites de fotos/PDFs)
OPENCODE_GO_API_KEY="sk-xxx"
VISION_MODEL="qwen3.7-plus"

# Microserviço de resultados ao vivo (Fly.io)
MICROSERVICE_URL="https://bolao-copa-microservice.fly.dev"
